{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "Global website settings like logo and section images.",
      "type": "object",
      "properties": {
        "logo": {
          "type": "string",
          "description": "The URL of the website logo."
        },
        "aboutImage": {
          "type": "string",
          "description": "The main image in the About section."
        },
        "statsBg": {
          "type": "string",
          "description": "Background image for the stats section."
        },
        "aboutBg": {
          "type": "string",
          "description": "Background image for the about section."
        },
        "footerBg": {
          "type": "string",
          "description": "Background image for the footer."
        }
      },
      "required": ["logo"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A food item in the menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category": { 
          "type": "string",
          "enum": ["Sushi Rolls", "Sashimi", "Platters", "Drinks"]
        },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "Settings",
      "description": "Global configuration document."
    },
    "/menu": {
      "schema": "MenuItem",
      "description": "Collection of menu items."
    }
  }
}
