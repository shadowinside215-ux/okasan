rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - logo: string (required) - The URL of the website logo.
    //
    // Collection: menu
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - description: string (optional)
    //   - category: string (required, enum: Sushi Rolls, Sashimi, Platters, Drinks)
    //   - image: string (required)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "dragonballsam86@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidSettings(data) {
      return data.keys().hasOnly(['logo']) &&
             isValidUrl(data.logo) &&
             data.logo.size() < 1000;
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['Sushi Rolls', 'Sashimi', 'Platters', 'Drinks'] &&
             isValidUrl(data.image) &&
             (!('description' in data) || (data.description is string && data.description.size() < 500)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /menu/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMenuItem(request.resource.data);
      allow update: if isAdmin() && isValidMenuItem(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
